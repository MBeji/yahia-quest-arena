{
  "title": "Practice: simple or continuous?",
  "difficulty": 1,
  "mode": "practice",
  "xpReward": 50,
  "rewardCoins": 10,
  "displayOrder": 1,
  "questions": [
    {
      "prompt": "Choose the correct form: \"She ___ to school every day.\"",
      "options": [
        { "id": "a", "text": "goes" },
        { "id": "b", "text": "is going" },
        { "id": "c", "text": "go" },
        { "id": "d", "text": "going" }
      ],
      "correctOption": "a",
      "explanation": "\"every day\" signals a habit, so we use the present simple with -es: she goes."
    },
    {
      "prompt": "Complete: \"Look! The baby ___.\"",
      "options": [
        { "id": "a", "text": "cries" },
        { "id": "b", "text": "is crying" },
        { "id": "c", "text": "cry" },
        { "id": "d", "text": "cried" }
      ],
      "correctOption": "b",
      "explanation": "\"Look!\" signals an action happening now, so we use the present continuous: is crying."
    },
    {
      "prompt": "Which word signals the present simple?",
      "options": [
        { "id": "a", "text": "now" },
        { "id": "b", "text": "at the moment" },
        { "id": "c", "text": "usually" },
        { "id": "d", "text": "Look!" }
      ],
      "correctOption": "c",
      "explanation": "Adverbs of frequency such as \"usually\" signal a habit (present simple)."
    },
    {
      "prompt": "Complete: \"He ___ football on Sundays.\"",
      "options": [
        { "id": "a", "text": "play" },
        { "id": "b", "text": "plays" },
        { "id": "c", "text": "is play" },
        { "id": "d", "text": "playing" }
      ],
      "correctOption": "b",
      "explanation": "Third person singular in the present simple takes -s: he plays."
    },
    {
      "prompt": "Choose the correct sentence:",
      "options": [
        { "id": "a", "text": "I am knowing the answer." },
        { "id": "b", "text": "I know the answer." },
        { "id": "c", "text": "I knows the answer." },
        { "id": "d", "text": "I am know the answer." }
      ],
      "correctOption": "b",
      "explanation": "\"know\" is a stative verb, so it is not used in the continuous: I know the answer."
    },
    {
      "prompt": "Complete: \"They ___ TV at the moment.\"",
      "options": [
        { "id": "a", "text": "watch" },
        { "id": "b", "text": "watches" },
        { "id": "c", "text": "are watching" },
        { "id": "d", "text": "is watching" }
      ],
      "correctOption": "c",
      "explanation": "\"at the moment\" signals now, so we use the present continuous with the plural subject they: are watching."
    }
  ]
}
