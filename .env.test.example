# =============================================================================
# E2E TEST environment — copy to `.env.test` and fill with your DEDICATED TEST
# Supabase project's values. `.env.test` is gitignored; this example is committed.
#
#   cp .env.test.example .env.test    # then edit
#   npm run e2e:doctor                # verify it's complete
#
# ⚠️  TEST PROJECT ONLY. Never put production credentials here: the authenticated
#     e2e suite SEEDS, RESETS and MUTATES data (wipes gameplay, sets coins, etc.).
#     A dedicated throwaway Supabase project is mandatory. Tooling refuses to run
#     against the known production ref as a safety net.
#
# Values come from Supabase → Project Settings → API (URL + keys) and
# → Database (connection string).
# =============================================================================

# --- Client (inlined by Vite at serve/build time) ---
VITE_SUPABASE_URL=https://your-test-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-test-anon-publishable-key

# --- Server / SSR (runtime, read from process.env) — same TEST project ---
SUPABASE_URL=https://your-test-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-test-anon-publishable-key

# --- Server only — TEST service-role secret (seeding / reset / adminDb) ---
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-secret

# --- Shared password for the 4 seeded accounts (free/premium/parent/admin) ---
E2E_USER_PASSWORD=choose-a-strong-password

# --- Optional: TEST Postgres connection URI, for `npm run e2e:db:push` ---
# Supabase → Project Settings → Database → Connection string → URI (port 5432).
# URL-encode the password. Leave unset if you apply migrations another way.
# TEST_SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-test-ref.supabase.co:5432/postgres
