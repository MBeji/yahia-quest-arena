{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "GENERATED by `npm run harness:sync` from harness/policy.json (permissions) + the hooks wired in scripts/harness/sync.mjs. DO NOT EDIT BY HAND — edit the source and re-run the sync (étude 25 D-4).",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run verify)",
      "Bash(npm run ci:verify)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npm run format)",
      "Bash(npm run audit:deps)",
      "Bash(npm run harness:check)",
      "Bash(npm run leak:check)",
      "Bash(npm run db:check-chain)",
      "Bash(npm test)",
      "Bash(npm run content:check)",
      "Bash(npm run content:qa)",
      "Bash(npm run content:qa:strict)",
      "Bash(npm run content:audit)",
      "Bash(npm run content:audit:strict)",
      "Bash(npm run content:build)",
      "Bash(npm run content:catalogue)",
      "Bash(npm outdated:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx supabase migration list:*)",
      "Bash(npx supabase db diff:*)",
      "Bash(npx supabase test db)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git ls-files:*)",
      "Bash(ls:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)"
    ],
    "deny": [
      "Bash(npx supabase db push:*)",
      "Bash(npx supabase db reset:*)",
      "Bash(supabase db push:*)",
      "Bash(supabase db reset:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-generated.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "node .claude/hooks/precommit-checks.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format-changed.mjs"
          }
        ]
      }
    ]
  }
}
