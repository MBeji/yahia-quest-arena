# Supabase configuration — REQUIRED for the app to run.
#
# Local dev: copy this file to `.env` and fill in the values.
# Deploy (Vercel): set the SAME keys in Project → Settings → Environment
# Variables, then redeploy. Values come from the Supabase dashboard:
# Project Settings → API.
#
# The app intentionally throws a descriptive error if any of these are
# missing (see src/shared/integrations/supabase/client*.ts).

# --- Client (injected at BUILD time by Vite; must be present when building) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- Server / SSR (RUNTIME) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- Server ONLY — never expose to the client, never prefix with VITE_ ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# --- Web Push notifications ---
# Generate the VAPID keypair once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-secret
VAPID_SUBJECT=mailto:you@example.com
# Same public key, inlined into the client bundle at BUILD time:
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`:
CRON_SECRET=your-long-random-cron-secret

# --- Error monitoring (Sentry) — OPTIONAL (off unless a DSN is set) ---
# Per-project DSN from Sentry → Project → Settings → Client Keys (DSN). Use an EU
# data-region project. Not a secret (it ships in the client bundle). See
# docs/environment-variables.md → "Error monitoring (Sentry)".
VITE_SENTRY_DSN=
# Optional server-runtime fallback (same value, no rebuild needed):
SENTRY_DSN=
