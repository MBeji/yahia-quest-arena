# Supabase configuration — REQUIRED for the app to run.
#
# Local dev: copy this file to `.env` and fill in the values.
# Deploy (Vercel): set the SAME keys in Project → Settings → Environment
# Variables, then redeploy. Values come from the Supabase dashboard:
# Project Settings → API.
#
# The app intentionally throws a descriptive error if any of these are
# missing (see src/shared/integrations/supabase/client*.ts).

# --- Client (injected at BUILD time by Vite; must be present when building) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- Server / SSR (RUNTIME) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- Server ONLY — never expose to the client, never prefix with VITE_ ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
