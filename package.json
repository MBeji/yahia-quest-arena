{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:check": "npm run build && node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=public-chromium --project=public-mobile",
    "test:e2e:auth": "playwright test --project=authed-chromium",
    "test:e2e:install": "playwright install chromium",
    "e2e:doctor": "node scripts/e2e/check-env.mjs",
    "e2e:db:push": "node scripts/e2e/setup-test-db.mjs",
    "e2e:seed": "node scripts/e2e/seed-test-users.mjs",
    "e2e:reset": "node scripts/e2e/reset-gameplay.mjs",
    "e2e:setup": "npm run e2e:db:push && npm run e2e:seed && npm run e2e:reset",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "content:check": "node --experimental-strip-types scripts/content/build.ts --check",
    "content:build": "node --experimental-strip-types scripts/content/build.ts",
    "content:qa": "node --experimental-strip-types scripts/content/qa.ts",
    "content:qa:strict": "node --experimental-strip-types scripts/content/qa.ts --strict",
    "verify": "npm run lint && npm run typecheck && npm run test",
    "audit:deps": "npm audit --omit=dev --audit-level=high --registry=https://registry.npmjs.org",
    "ci:verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run build:check && npm run audit:deps && npm run content:qa:strict",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{js,mjs,cjs,json,css,md,html,yml,yaml}": [
      "prettier --write"
    ]
  },
